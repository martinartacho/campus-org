APP_NAME=Laravel
APP_ENV=local

# =============================================================================
# 🚨 ADVERTÈNCIA CRÍTICA DE SEGURETAT - APP_KEY 🚨
# =============================================================================
# 
# ⚠️ NO CAMVIAR MAI L'APP_KEY SENSE PROCEDIMENT SEGUR!
# 
# 💥 UN CANVI D'APP_KEY CORROMPRÀ PERMANENTEMENT:
#    - Totes les dades bancàries encriptades es perdran
#    - Els professors no podran accedir al dashboard
#    - Error "The payload is invalid" a tot el sistema
#    - Dades personals sensibles es corrompen irreversiblement
# 
# ✅ PROCEDIMENT SEGUR PER CANVI D'APP_KEY:
#    1. Fer backup complet de base de dades
#    2. Exportar dades sensibles existents
#    3. Canviar APP_KEY només si és absolutament necessari
#    4. Executar: php artisan banking:migrate-all-to-encryption --force
#    5. Verificar: php artisan banking:verify-integrity
# 
# 🚨 EN CAS D'EMERGÈNCIA:
#    - Contactar: security@example.com
#    - Veure: SECURITY_WARNINGS.md
#    - Executar: php artisan banking:emergency-recovery
# 
# =============================================================================
APP_KEY=

# ⚠️ En producción siempre usar APP_DEBUG=false para no exponer trazas de error al usuario
APP_DEBUG=false
APP_URL=http://example.local

APP_LOCALE=ca
APP_FALLBACK_LOCALE=ca
APP_FAKER_LOCALE=es_CA

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=


SESSION_DRIVER=database
SESSION_LIFETIME=120
# 🔐 Activar encriptación de sesiones para proteger datos sensibles
# Nota: Al activar esto, las sesiones existentes se invalidarán. Planificar ventana de mantenimiento.
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
## MAIL_ALWAYS_TO=preview@mailpit

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

MAIL_ADDRESS_CONTACTE=contact@example.com
POSTAL_ADDRESS_CONTACTE="Rambla, 4, edifici CTUG"
PHONE_CONTACTE=  "+36 xxx xxx xxx"
CIF_CONTACTE=  "B123456Z"

SEEDER_ADMIN_PASSWORD=Admin.123!
SEEDER_DEFAULT_PASSWORD=Campus2026!
SEEDER_EMAIL_DOMAIN=test.local
# Els primers 5 teachers/students usen DEFAULT, la resta aleatòries
SEEDER_RANDOM_PASSWORD_THRESHOLD=5

# =============================================================================
# 🚨 ADVERTÈNCIES ADDICIONALS DE SEGURETAT 🚨
# =============================================================================
#
# ⚠️ PASSWORDS DE SEEDER:
#    - Nomes per entorns de desenvolupament/testing
#    - MAI utilitzar en producció
#    - Canviar abans de fer: php artisan db:seed
#
# 🔐 PRODUCCIÓ:
#    - APP_DEBUG=false
#    - Utilitzar claus fortes i úniques
#    - Configurar HTTPS correctament
#    - Activar logs de seguretat
#
# 📊 BASE DE DADES:
#    - Utilitzar credencials fortes
#    - Restringir accés per IP
#    - Fer backups regulars
#    - Encriptar backups si és possible
#
# 🌍 SERVIDOR:
#    - Mantenir sistema actualitzat
#    - Configurar firewall correctament
#    - Monitoritzar activitat sospitosa
#    - Utilitzar HTTPS obligatòriament
#
# =============================================================================
# STRIPE PAYMENT CONFIGURATION
# =============================================================================
# Obtener claves desde: https://dashboard.stripe.com/apikeys
# Modo testing usa claves que empiezan con pk_test_ y sk_test_
# Modo producción usa claves que empiezan con pk_live_ y sk_live_

STRIPE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Para configurar webhook:
# 1. Ir a: https://dashboard.stripe.com/webhooks
# 2. Crear endpoint: https://tu-dominio.com/stripe/webhook
# 3. Seleccionar eventos: checkout.session.completed, payment_intent.succeeded
# 4. Copiar el secreto de firma (signing secret)
# =============================================================================

# =============================================================================
# Per més informació de seguretat, veure:
# - README.md (secció d'advertències crítiques)
# - RELEASE_NOTES.md (procediments de seguretat)
# - SECURITY_WARNINGS.md (guía d'emergència)
# =============================================================================
