    <script>
    function togglePaymentFields() {
        const paymentType = document.getElementById('payment_type').value;
        const bankingFields = document.getElementById('banking-fields');
        // Mostrar/ocultar camps bancaris
        if (paymentType === 'own') {
            bankingFields.classList.remove('hidden');
        } else {
            bankingFields.classList.add('hidden');
        }
    }
    
    function syncFiscalId() {
        const dni = document.getElementById('dni').value;
        const fiscalId = document.getElementById('fiscal_id');
        
        // Si el fiscal_id està buit, sincronitzar amb el DNI
        if (!fiscalId.value || fiscalId.value === dni) {
            fiscalId.value = dni;
        }
    }
    
    // Inicialitzar al carregar la pàgina
    document.addEventListener('DOMContentLoaded', function() {
        togglePaymentFields();
        
        // Sincronitzar fiscal_id canviant el DNI
        document.getElementById('dni').addEventListener('input', syncFiscalId);
        
        // Sincronitzar fiscal_id al carregar si està buit
        syncFiscalId();
    });
    </script>
</x-app-layout>
