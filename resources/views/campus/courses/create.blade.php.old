@push('scripts')
<script>
document.addEventListener('DOMContentLoaded', function() {
    @if($baseCourse)
        // Seleccionar automàticament "Curs Impartit (Instància)"
        const instanceRadio = document.querySelector('input[name="is_base_course"][value="0"]');
        const baseRadio = document.querySelector('input[name="is_base_course"][value="1"]');
        
        if (instanceRadio && baseRadio) {
            instanceRadio.checked = true;
            baseRadio.checked = false;
            
            // Disparar l'event per mostrar camps d'instància
            const event = new Event('change', { bubbles: true });
            instanceRadio.dispatchEvent(event);
            
            // Seleccionar el curs base
            setTimeout(() => {
                const parentBaseSelect = document.getElementById('parent_base_id');
                if (parentBaseSelect) {
                    parentBaseSelect.value = '{{ $baseCourse->id }}';
                    
                    // Disparar l'event per carregar dades
                    const changeEvent = new Event('change', { bubbles: true });
                    parentBaseSelect.dispatchEvent(changeEvent);
                }
            }, 100);
        }
    @else
        // Si no hi ha baseCourse, redirigir a llistat
        setTimeout(() => {
            window.location.href = '{{ route("campus.courses.index") }}';
        }, 2000);
    @endif
});
</script>
@endpush
@endsection
